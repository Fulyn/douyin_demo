<?xml version="1.0" encoding="utf-8"?>
<!-- 抖音风首页：MainActivity 直接承载，无需再套 Fragment。 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/home_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/video_background"
    tools:context=".MainActivity">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/channelPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <HorizontalScrollView
        android:id="@+id/channelScrollView"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_gravity="top"
        android:background="@android:color/transparent"
        android:fillViewport="false"
        android:overScrollMode="never"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:scrollbars="none">

        <FrameLayout
            android:id="@+id/channelBarContent"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layoutDirection="ltr">

            <LinearLayout
                android:id="@+id/rowForText"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal" />

            <View
                android:id="@+id/channelIndicator"
                android:layout_width="26dp"
                android:layout_height="2dp"
                android:layout_gravity="bottom|start"
                android:layout_marginBottom="8dp"
                android:background="@android:color/white" />
        </FrameLayout>
    </HorizontalScrollView>
</FrameLayout>
